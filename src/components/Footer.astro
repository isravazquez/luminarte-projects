---
import { CONTACT_PHONE, CONTACT_EMAIL, WHATSAPP_BASE, SITE_URL, SOCIAL_LINKS } from "@lib/constants";

const currentYear = new Date().getFullYear();
---

<footer class="mt-auto w-full">
  <div class="mx-auto w-full max-w-7xl px-4 pb-3">
    <div class="mb-3 rounded-2xl border border-white/10 bg-white/[0.04] p-4 md:p-5">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
        <div class="flex items-center gap-3">
          <img
            src="/logo.png"
            width="72"
            height="36"
            alt="LuminArte"
            class="h-10 w-auto drop-shadow-md"
          />
          <div>
            <p class="text-sm font-semibold text-white">LuminArte</p>
            <p class="text-xs text-white/70">
              Propuestas visuales y acompañamiento para tu proyecto
            </p>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-3 text-sm text-white/85">
          <a href={`tel:${CONTACT_PHONE.replace(/\s/g, "")}`} class="hover:text-white">
            {CONTACT_PHONE}
          </a>
          <span class="hidden text-white/30 md:inline">&bull;</span>
          <a href={`mailto:${CONTACT_EMAIL}`} class="hover:text-white">
            {CONTACT_EMAIL}
          </a>
          <span class="hidden text-white/30 md:inline">&bull;</span>
          <a
            href={WHATSAPP_BASE}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-white"
          >
            WhatsApp
          </a>
        </div>
      </div>

      <div class="mt-4 flex flex-col items-center justify-between gap-3 border-t border-white/8 pt-4 md:flex-row">
        <p class="text-xs text-white/65">
          También puedes encontrarnos en redes
        </p>
        <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm text-white/75">
          {SOCIAL_LINKS.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.ariaLabel}
              class="hover:text-white"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <div
      class="text-white flex flex-col justify-center items-center text-center pb-2"
    >
      <p class="font-semibold">
        &copy; {currentYear} All rights reserved |
        <a
          href={SITE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="text-red-600 font-semibold cursor-pointer"
        >
          {" "}Lumin<span class="text-white">Arte</span>
        </a>
      </p>
    </div>
  </div>
</footer>

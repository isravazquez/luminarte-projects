---
const {
  url,
  name = "N/A",
  isInteractive = true,
  height = "360px",
  cameraControls = true,
  showHint = true,
  loadingLabel = "Cargando vista 3D",
  showBloomToggle = true,
  class: className = "",
} = Astro.props;
---

<div class={`lv-model-shell ${className}`} data-model-shell>
  <div class="lv-model-loading" data-model-loading>
    <div class="lv-spinner" aria-hidden="true"></div>
    <p>{loadingLabel}</p>
    <div class="lv-loading-row" aria-hidden="true">
      <span>Cargando modelo</span>
      <span data-model-progress-label>0%</span>
    </div>
    <small>Esto puede tardar unos segundos dependiendo de tu conexión.</small>
  </div>

  <div class="lv-touch-gate hidden" data-model-touch-gate aria-hidden="true">
    <button type="button" class="lv-touch-gate-btn" data-model-enable-touch>
      Interactuar
    </button>
  </div>

  <button
    type="button"
    class="lv-touch-lock hidden"
    data-model-disable-touch
    aria-label="Bloquear interacción del modelo"
    title="Bloquear interacción"
  >
    Bloquear giro
  </button>

  {
    showBloomToggle && (
      <button
        type="button"
        class="btn-press btn-tertiary lv-bloom-toggle hidden"
        data-model-bloom-toggle
        aria-pressed="true"
      >
        Apagar
      </button>
    )
  }

  <model-viewer
    class="lv-model-viewer"
    style={`height:${height}; width:100%;`}
    src={url}
    ar
    autoplay
    ar-placement="wall"
    alt={name}
    auto-rotate
    auto-rotate-delay="0"
    exposure="1.6"
    shadow-intensity="0.9"
    shadow-softness="0.85"
    environment-image="neutral"
    loading="eager"
    reveal="auto"
    {...cameraControls ? { "camera-controls": "" } : {}}
  >
    <effect-composer data-selective-composer render-mode="quality">
      <selective-bloom-effect
        data-selective-bloom
        strength="1.6"
        radius="0.55"
        threshold="0.1"
      ></selective-bloom-effect>
      <color-grade-effect></color-grade-effect>
    </effect-composer>

    <div class="lv-progress" slot="progress-bar" aria-hidden="true">
      <div class="lv-progress-bar" data-model-progress></div>
    </div>

    <button
      class={`${isInteractive ? "" : "hidden "}lv-ar-button`}
      slot="ar-button"
      type="button"
    >
      Ver en AR
    </button>
  </model-viewer>
</div>

{
  showHint && (
    <p class="lv-hint">
      Arrastra para girar el modelo y usa zoom para revisar detalles.
    </p>
  )
}

<script is:inline>
  (() => {
    const bindModelShells = () => {
      document.querySelectorAll("[data-model-shell]").forEach((shell) => {
        if (shell.dataset.bound === "true") return;
        shell.dataset.bound = "true";

        const viewer = shell.querySelector("model-viewer");
        const loading = shell.querySelector("[data-model-loading]");
        const progressBar = shell.querySelector("[data-model-progress]");
        const progressLabel = shell.querySelector("[data-model-progress-label]");
        const touchGate = shell.querySelector("[data-model-touch-gate]");
        const enableTouchBtn = shell.querySelector("[data-model-enable-touch]");
        const disableTouchBtn = shell.querySelector("[data-model-disable-touch]");
        const bloomToggleBtn = shell.querySelector("[data-model-bloom-toggle]");
        const selectiveComposer = shell.querySelector("[data-selective-composer]");
        const selectiveBloom = shell.querySelector("[data-selective-bloom]");

        if (!viewer || !loading || !progressBar || !progressLabel || !touchGate || !enableTouchBtn || !disableTouchBtn) return;

        const isTouchDevice = window.matchMedia("(pointer: coarse)").matches;
        const shouldLockTouch = isTouchDevice && viewer.hasAttribute("camera-controls");

        const setTouchLock = (locked) => {
          shell.classList.toggle("is-touch-locked", locked);
          shell.classList.toggle("is-touch-unlocked", !locked);
          touchGate.classList.toggle("hidden", !locked);
          touchGate.setAttribute("aria-hidden", locked ? "false" : "true");
          disableTouchBtn.classList.toggle("hidden", locked);
        };

        if (shouldLockTouch) {
          setTouchLock(true);
        }

        const baseBloomStrength = Number(selectiveBloom?.getAttribute("strength") || "1.6");
        let bloomEnabled = true;

        const setBloomToggleState = (enabled) => {
          bloomEnabled = enabled;
          if (!bloomToggleBtn) return;
          bloomToggleBtn.textContent = enabled ? "Apagar" : "Encender";
          bloomToggleBtn.setAttribute("aria-pressed", enabled ? "true" : "false");
        };

        const setBloomToggleVisibility = (visible) => {
          if (!bloomToggleBtn) return;
          bloomToggleBtn.classList.toggle("hidden", !visible);
          bloomToggleBtn.setAttribute("aria-hidden", visible ? "false" : "true");
        };

        setBloomToggleState(true);
        setBloomToggleVisibility(false);
        const applySelectiveBloom = () => {
          if (!selectiveComposer || !selectiveBloom || !selectiveComposer.selection) {
            return;
          }

          const selection = [];
          const hasEmissiveChannel = (material) => {
            if (!material || !material.emissive) return false;
            const emissive = material.emissive;
            const emissiveIntensity =
              typeof material.emissiveIntensity === "number" ? material.emissiveIntensity : 1;
            return emissiveIntensity > 0 && (emissive.r > 0 || emissive.g > 0 || emissive.b > 0);
          };

          const hasEmissiveMaterial = (obj) => {
            if (!obj || !obj.material) return false;
            if (Array.isArray(obj.material)) {
              return obj.material.some((material) => hasEmissiveChannel(material));
            }
            return hasEmissiveChannel(obj.material);
          };

          selectiveComposer.selection.forEach((obj) => {
            const matchesEmissive = hasEmissiveMaterial(obj);

            const shouldSelect = matchesEmissive;

            if (shouldSelect) {
              selection.push(obj);
            }
          });

          selectiveBloom.selection = selection;
          const hasSelectableBloomMeshes = selection.length > 0;
          setBloomToggleVisibility(hasSelectableBloomMeshes);
          selectiveBloom.strength =
            bloomEnabled && hasSelectableBloomMeshes ? baseBloomStrength : 0;
        };

        bloomToggleBtn?.addEventListener("click", () => {
          setBloomToggleState(!bloomEnabled);
          applySelectiveBloom();
        });

        if (selectiveComposer && selectiveBloom) {
          selectiveComposer.addEventListener("updated-selection", applySelectiveBloom);
          viewer.addEventListener(
            "load",
            () => {
              requestAnimationFrame(applySelectiveBloom);
            },
            { once: true },
          );
        }

        const markLoaded = () => {
          shell.classList.add("is-loaded");
          loading.setAttribute("aria-hidden", "true");
          progressBar.style.width = "100%";
          progressLabel.textContent = "100%";
        };

        viewer.addEventListener("progress", (event) => {
          const detail = event.detail || {};
          const totalProgress =
            typeof detail.totalProgress === "number" ? detail.totalProgress : 0;
          const pct = Math.round(totalProgress * 100);
          progressBar.style.width = `${pct}%`;
          progressLabel.textContent = `${pct}%`;
        });

        viewer.addEventListener("load", markLoaded, { once: true });
        viewer.addEventListener("error", () => {
          loading.innerHTML =
            "<p>No pudimos cargar el modelo 3D.</p><small>Intenta recargar la página o contáctanos por WhatsApp.</small>";
          shell.classList.remove("is-loaded");
        });

        viewer.addEventListener("camera-change", () => {
          shell.classList.add("is-interacting");
        }, { once: true });

        enableTouchBtn.addEventListener("click", () => {
          setTouchLock(false);
          shell.classList.add("is-interacting");
        });

        disableTouchBtn.addEventListener("click", () => {
          setTouchLock(true);
        });
      });
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", bindModelShells, { once: true });
    } else {
      bindModelShells();
    }
  })();
</script>

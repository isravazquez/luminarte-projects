---
export type GalleryItem = {
  type: "image" | "video";
  url: string;
};

interface Props {
  items: GalleryItem[];
  title: string;
  videoPoster?: string;
  projectSlug?: string;
  projectName?: string;
}

const {
  items,
  title,
  videoPoster = "",
  projectSlug = "",
  projectName = title,
} = Astro.props;
---

{
  items.length > 0 && (
    <section
      class="mt-6"
      data-gallery-root
      data-gallery-project-slug={projectSlug}
      data-gallery-project-name={projectName}
    >
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-lg font-semibold md:text-xl">Apoyos visuales</h2>
        <span class="text-xs text-white/60">
          {items.length} {items.length === 1 ? "elemento" : "elementos"}
        </span>
      </div>

      <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {items.map((item, index: number) => (
          <button
            type="button"
            data-gallery-open
            data-gallery-index={index}
            data-gallery-src={item.url}
            data-gallery-type={item.type}
            data-gallery-poster={item.type === "video" ? videoPoster : ""}
            data-gallery-alt={`${item.type === "video" ? "Video" : "Referencia visual"} ${index + 1} de ${title}`}
            class="group block overflow-hidden rounded-2xl border border-white/10 bg-black/20 text-left cursor-pointer"
            aria-label={`Abrir ${item.type === "video" ? "video" : "imagen"} ${index + 1} en pantalla completa`}
          >
            <div class="relative aspect-[16/10] overflow-hidden">
              {
                item.type === "video" ? (
                  <video
                    src={item.url}
                    poster={videoPoster}
                    muted
                    playsinline
                    preload="metadata"
                    class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
                  />
                ) : (
                  <img
                    src={item.url}
                    alt={`Referencia visual ${index + 1} de ${title}`}
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
                  />
                )
              }
              {
                item.type === "video" && (
                  <>
                    <span class="absolute left-2 top-2 rounded-lg bg-black/60 px-2 py-1 text-xs font-semibold text-white">
                      Video
                    </span>
                    <span
                      aria-hidden="true"
                      class="pointer-events-none absolute inset-0 grid place-items-center"
                    >
                      <span class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-black/28 text-white/95 shadow-lg backdrop-blur-sm">
                        <span class="ml-1 text-3xl leading-none">&#9654;</span>
                      </span>
                    </span>
                  </>
                )
              }
              <span class="absolute bottom-2 left-2 rounded-lg bg-black/55 px-2 py-1 text-xs font-medium text-white">
                {item.type === "video" ? "Reproducir" : "Ampliar"}
              </span>
            </div>
          </button>
        ))}
      </div>
    </section>
  )
}
